---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// IMPORTACIONES DE IMÁGENES (Manteniendo consistencia y optimización)
import imgRemera from '~/assets/images/remera-ws.png';
import imgParche from '~/assets/images/parche-litoral.png';
import imgRitohouse from '~/assets/images/pieza-yeso.png';
import imgGuantes from '~/assets/images/guantes-cuero.png';
import imgGorros from '~/assets/images/gorros-capitulo.png';
import imgVelas from '~/assets/images/velas-simbolicas.png';

const metadata = {
  title: 'Colabora — Gran Chapter de Widows Sons Uruguay',
};
---

<Layout metadata={metadata}>
  <Features2
    title="Sostenibilidad de nuestra Obra Filantrópica"
    subtitle="A través del Gran Chapter, las contribuciones se administran de manera centralizada para potenciar e impulsar las intervenciones sociales de todos nuestros capítulos legítimos en el territorio nacional."
    items={[
      {
        title: 'Tienda Oficial Nacional',
        description: 'Adquiere el merchandising legítimo avalado por el Gran Capítulo. El 100% de los fondos se destina al fondo nacional de ayuda social.',
        icon: 'tabler:shopping-bag',
        callToAction: { text: 'Ver Catálogo', href: '#tienda', variant: 'link' },
      },
      {
        title: 'Sponsors e Instituciones',
        description: 'Programa de alianzas corporativas de alcance nacional para empresas comprometidas con el desarrollo comunitario y el civismo.',
        icon: 'tabler:building-store',
        callToAction: { text: 'Saber más', href: '#sponsors', variant: 'link' },
      },
      {
        title: 'Donación Civil General',
        description: 'Canal seguro para personas físicas que deseen aportar recursos o bienes en desuso que sirvan a nuestras intervenciones en todo el país.',
        icon: 'tabler:heart-handshake',
        callToAction: { text: '¿Cómo donar?', href: '#donaciones', variant: 'link' },
      },
    ]}
  />

  <section id="tienda" class="px-4 py-16 mx-auto max-w-7xl lg:py-20">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2 class="text-[#d4af37] font-bold tracking-tight text-3xl sm:text-4xl uppercase mb-4">Tienda Oficial Nacional</h2>
      <p class="text-zinc-400 italic">Cada compra consolida el Fondo Central de Emergencia y Obras Sociales de la Orden en Uruguay, estos articulos de exclusiva venta para miembros de WIDOWS SONS.</p>
    </div>

    <div class="grid gap-6 row-gap-5 md:grid-cols-3">
      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgRemera} alt="Remera Oficial WS Uruguay" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Remera Oficial WS Gran Capítulo</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Algodón premium con el emblema oficial nacional en espalda y frente.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$1.200</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgParche} alt="Parche Institucional Nacional" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Parche Institucional Oficial</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Parche oficial bordado de alta definición para el distintivo de la orden.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$850</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgRitohouse} alt="Escuadra y Compás WS Edición Yeso" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Escuadra y Compás WS (Edición Yeso)</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Arte masónico artesanal exclusivo producido por Ritohouse para la Orden.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$1.200</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgGuantes} alt="Guantes de cuero personalizados" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Guantes de Cuero Personalizados</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Cuero legítimo para ruta con grabado láser del Gran Capítulo.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$1.850</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgGorros} alt="Gorros de nuestro capítulo" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Gorros Oficiales Nacionales</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Ajustables con el bordado heráldico en hilos dorados.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$850</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>

      <div class="flex flex-col p-4 border border-[#d4af37]/20 rounded-lg bg-zinc-900/50 hover:border-[#d4af37] transition-all">
        <div class="aspect-square bg-zinc-800 rounded mb-4 overflow-hidden flex items-center justify-center">
          <Image src={imgVelas} alt="Velas decorativas línea simbólica" class="object-cover w-full h-full" />
        </div>
        <h3 class="font-bold text-white uppercase tracking-wider text-sm">Velas Línea Simbólica Nacional</h3>
        <p class="text-xs text-zinc-400 mt-2 mb-4">Línea de velas artesanales con simbología de los Widows Sons.</p>
        <div class="mt-auto flex justify-between items-center">
          <span class="text-[#d4af37] font-bold">$450</span>
          <a href="/#contacto" class="text-[10px] bg-[#d4af37] text-black px-3 py-1 rounded font-bold uppercase hover:bg-white transition-colors">Consultar</a>
        </div>
      </div>
    </div>
  </section>

  <section id="sponsors" class="px-4 py-16 mx-auto max-w-7xl lg:py-20 bg-zinc-900/10">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2 class="text-[#d4af37] font-bold tracking-tight text-3xl sm:text-4xl uppercase mb-4">Programa de Patrocinio Institucional</h2>
      <p class="text-zinc-400">Una oportunidad para que empresas de todo el país vinculen su marca con una red organizada de alcance nacional dedicada al servicio y la ayuda social.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      <div class="p-6 border border-zinc-800 rounded-lg bg-black hover:border-[#d4af37]/50 transition-all flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-white font-bold uppercase text-lg">Aliado Corporativo</h3>
          <Icon name="tabler:bike" class="w-6 h-6 text-[#d4af37]" />
        </div>
        <ul class="text-sm text-zinc-400 space-y-2 mb-6 flex-grow">
          <li>• Presencia en la plataforma web nacional.</li>
          <li>• Reconocimiento formal en el balance anual de obras.</li>
          <li>• Certificado Oficial del Gran Capítulo.</li>
        </ul>
        <a href="/#contacto" class="w-full text-center py-2 border border-[#d4af37] text-[#d4af37] font-bold uppercase text-xs rounded">Solicitar Información</a>
      </div>

      <div class="p-6 border-2 border-[#d4af37] rounded-lg bg-zinc-900 flex flex-col transform lg:scale-105 shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-white font-bold uppercase text-lg">Mecenas Nacional</h3>
          <Icon name="tabler:crown" class="w-6 h-6 text-[#d4af37]" />
        </div>
        <p class="text-[10px] text-[#d4af37] font-bold uppercase mb-2">Presencia Premium</p>
        <ul class="text-sm text-zinc-300 space-y-2 mb-6 flex-grow">
          <li>• Logotipo destacado en campañas de comunicación digital.</li>
          <li>• Presencia publicitaria institucional en asambleas y eventos nacionales.</li>
          <li>• Co-branding oficial en parches conmemorativos nacionales.</li>
        </ul>
        <a href="/#contacto" class="w-full text-center py-2 bg-[#d4af37] text-black font-bold uppercase text-xs rounded">Vincular Empresa</a>
      </div>

      <div class="p-6 border border-zinc-800 rounded-lg bg-black hover:border-[#d4af37]/50 transition-all flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-white font-bold uppercase text-lg">Aliado Estratégico</h3>
          <Icon name="tabler:hand-stop" class="w-6 h-6 text-[#d4af37]" />
        </div>
        <ul class="text-sm text-zinc-400 space-y-2 mb-6 flex-grow">
          <li>• Acuerdos de provisión de insumos críticos o logística nacional.</li>
          <li>• Habilitación como base oficial de acopio inter-capitular.</li>
          <li>• Colaboración en infraestructura de ayuda civil.</li>
        </ul>
        <a href="/#contacto" class="w-full text-center py-2 border border-[#d4af37] text-[#d4af37] font-bold uppercase text-xs rounded">Proponer Convenio</a>
      </div>
    </div>
  </section>

  <section id="donaciones" class="px-4 py-16 mx-auto max-w-7xl lg:py-20 bg-zinc-900/30 rounded-lg">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2 class="text-[#d4af37] font-bold tracking-tight text-3xl sm:text-4xl uppercase mb-4">Donación de la Sociedad Civil</h2>
      <p class="text-zinc-400">Canalizamos las intenciones solidarias individuales para distribuirlas estratégicamente donde la necesidad sea prioritaria.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      <div class="p-5 border border-[#d4af37]/20 rounded shadow-sm bg-black">
        <h3 class="mb-2 font-bold text-white uppercase">Contribuciones de Bienes Materiales</h3>
        <p class="text-sm text-zinc-300">Recibimos herramientas, equipamientos logísticos, vestimenta utilitaria o materiales aptos para ser distribuidos a través de las redes de los capítulos regionales legítimos.</p>
      </div>
      <div class="p-5 border border-[#d4af37]/20 rounded shadow-sm bg-black">
        <h3 class="mb-2 font-bold text-white uppercase">Fondo Nacional de Filantropía</h3>
        <p class="text-sm text-zinc-300">Aportaciones monetarias destinadas exclusivamente a la adquisición de insumos de emergencia médica, alimenticia o de reconstrucción civil a gran escala.</p>
      </div>
    </div>
  </section>

  <CallToAction
    actions={[{ variant: 'primary', text: 'Contactar a Secretaría', href: '/#contacto' }]}
    title="¿Deseas formalizar un aporte?"
    subtitle="Ponte en contacto con la Secretaría General del Gran Capítulo para coordinar la logística nacional o instrumentar transferencias bancarias institucionales."
  />
</Layout>
