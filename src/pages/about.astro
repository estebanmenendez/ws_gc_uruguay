---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Quiénes Somos — Gran Chapter de Widows Sons Uruguay',
};
---

<Layout metadata={metadata}>
  <!-- 1. IDENTIDAD INSTITUCIONAL (ENFOQUE NACIONAL) -->
  <Hero
    tagline="Máxima Autoridad Nacional"
    image={{
      src: '~/assets/images/img1.png',
      alt: 'Gran Chapter de Widows Sons Uruguay',
    }}
  >
    <Fragment slot="title">
      Widows Sons <br />
      <span class="text-[#d4af37] dark:text-[#d4af37]">Gran Chapter de Uruguay</span>
    </Fragment>

    <Fragment slot="subtitle">
      Somos el cuerpo gobernante y la máxima autoridad representativa de los Maestros Masones activos que comparten la pasión por el motociclismo en todo el Uruguay. Bajo nuestra carta patente, velamos por el cumplimiento de los principios universales de la Masonería, guiando y unificando los esfuerzos de nuestros Chapters subordinados en sus misiones de servicio, honor y filantropía a nivel nacional.
    </Fragment>
  </Hero>

  <!-- 2. NUESTRA MISIÓN -->
  <Features3
    title="Nuestra Misión Nacional"
    subtitle="Gobernar con rectitud, unificar las rutas y expandir la cadena de unión filantrópica."
    columns={4}
    items={[
      { title: 'Filantropía', description: 'Coordinación Nacional', icon: 'tabler:heart-handshake' },
      { title: 'Carta Patente', description: 'Nuestra Base Legal', icon: 'tabler:gavel' },
      { title: 'Unidad', description: 'Nuestro Impacto', icon: 'tabler:users' },
      { title: 'Fraternidad', description: 'Nuestro Motor', icon: 'tabler:engine' },
    ]}
    classes={{
      icon: 'text-[#d4af37]',
    }}
  />

  <!-- 3. JURISDICCIÓN Y CAPÍTULOS (ESTRATEGIA DE CORRELACIÓN) -->
  <Features3
    title="Jurisdicción y Chapters Activos"
    subtitle="Como Órgano Madre, el Gran Chapter coordina, respalda y valida las acciones de las extensiones legítimas de la hermandad en el territorio uruguayo."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Gran Chapter (Sede Central)',
        description: 'Punto de coordinación general, gestión de membresías nacionales y relaciones internacionales de la orden.',
        icon: 'tabler:shield-checkered',
      },
      {
        title: 'Chapter Río Uruguay',
        description: 'Jurisdicción del litoral oeste (Río Negro, Paysandú, Salto, Soriano), coordinando rutas y filantropía regional.',
        icon: 'tabler:map-pin-filled',
      },
      {
        title: 'Chapter Río Cuareim',
        description: 'Jurisdicción y presencia en la frontera norte, uniendo lazos fraternales y misiones solidarias en los límites del territorio.',
        icon: 'tabler:map-pin-filled',
      },
    ]}
    classes={{
      icon: 'text-[#d4af37]',
    }}
  />

  <!-- 4. NUESTROS VALORES -->
  <Steps2
    title="Nuestros Valores Rectores"
    subtitle="Los pilares institucionales que guían la gobernanza y cada kilómetro de nuestra marcha."
    items={[
      {
        title: 'Institucionalidad y Orden',
        description: 'Preservación de la regularidad, las tradiciones de la orden y el respeto a las autoridades masónicas.',
      },
      {
        title: 'Filantropía Centralizada',
        description: 'Estrategia de apoyo y distribución de recursos para maximizar el impacto social en las comunidades vulnerables.',
      },
      {
        title: 'Unidad de la Cadena',
        description: 'Coherencia y cohesión absoluta entre todos los capítulos del país bajo un mismo espíritu fraternal.',
      },
    ]}
  />

  <!-- 5. NUESTRO COMPROMISO -->
  <Steps2
    title="Nuestro Compromiso Nacional"
    subtitle="Garantizamos la solidez y transparencia de nuestra hermandad para construir confianza y dejar huella en la sociedad."
    isReversed={true}
    callToAction={{
      text: 'Ver Actividades Nacionales',
      href: '/blog',
    }}
    items={[
      {
        title: 'Acción Regulada',
        description: 'Respaldamos institucionalmente cada intervención de nuestros chapters.',
        icon: 'tabler:tool',
      },
      {
        title: 'Vínculo Fraternal',
        description: 'Establecemos puentes sólidos entre los diferentes capítulos y la sociedad civil.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Referente Institucional',
        description: 'Máximo ejemplo de civismo, regularidad y rectitud masónica en las rutas públicas.',
        icon: 'tabler:certificate',
      },
    ]}
    classes={{
      icon: 'text-[#d4af37]',
    }}
  />

  <!-- 6. TERRITORIO DE INFLUENCIA -->
  <Features2
    title="Ámbito de Gestión"
    tagline="Jurisdicción"
    columns={3}
    items={[
      {
        title: 'Territorio Nacional',
        description: 'Gobernanza completa que abarca la totalidad de los departamentos del Uruguay.',
      },
      {
        title: 'Logias Regulares',
        description: 'Vinculación directa con los puntos de encuentro y talleres de la masonería nacional.',
      },
      {
        title: 'Rutas de Integración',
        description: 'Supervisión de encuentros inter-capitulares y paradas solidarias conjuntas.',
      },
    ]}
  />

  <!-- 7. CONTACTO CENTRALIZADO -->
  <Features2
    title="Contacto Institucional Central"
    tagline="Comunícate"
    columns={2}
    items={[
      {
        title: 'Secretaría General',
        description: 'Coordinación de convenios empresariales, sponsors nacionales y propuestas filantrópicas.',
        icon: 'tabler:messages',
      },
      {
        title: 'Regularización y Membresía',
        description: 'Trámites de afiliación y validación de credenciales para Maestros Masones en el país.',
        icon: 'tabler:id-badge-2',
      },
    ]}
    classes={{
      icon: 'text-[#d4af37]',
    }}
  />
</Layout>
